# --- Database (Vercel Postgres / Neon) ---
# Runtime + tests. Locally, connect as `pathway_app` (NOSUPERUSER, NOBYPASSRLS)
# so RLS policies actually enforce against the app's identity, the way Neon
# does in production. Example: postgres://pathway_app:pathway_app_dev@localhost:5432/pathway_dev
DATABASE_URL=
# Admin URL — drizzle-kit migrate (DDL) and scripts/seed.ts. Connects as
# the docker superuser locally; Neon's owner role in production. Example:
# postgres://postgres:postgres@localhost:5432/pathway_dev
DATABASE_URL_ADMIN=

# --- Better Auth ---
# 32+ char random string; generate with: openssl rand -hex 32
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000

# --- Resend (email) ---
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@example.com

# --- Vercel Blob (file uploads) ---
BLOB_READ_WRITE_TOKEN=

# --- Background jobs ---
CRON_SECRET=
QUEUE_SECRET=

# --- Sentry ---
# Server-side DSN. Same value goes in NEXT_PUBLIC_SENTRY_DSN — both are needed
# (Next.js does NOT inline server-only env vars into the browser bundle, so
# client-side errors require the NEXT_PUBLIC_ variant separately).
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
# Required for source-map upload in production builds. Your Sentry org slug
# and project slug — find them in the Sentry project URL.
SENTRY_ORG=
SENTRY_PROJECT=

# --- App URLs ---
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- AI Workflow Builder (optional; graceful disable when key missing) ---
# Anthropic API key. Leave blank to disable the AI Workflow Builder —
# the rest of the engine is unaffected; users see a clear
# "AI Workflow Builder is not configured" error if they try to use it.
ANTHROPIC_API_KEY=
# Default model. Override only if you need a specific Claude version.
AI_WORKFLOW_BUILDER_MODEL=claude-sonnet-4-6
# Rate-limit defaults — OPERATOR-COST / abuse backstop, NOT a user paywall.
# Defaults are generous (invisible to honest use; hard ceiling against
# runaway / abuse / bug). See src/modules/ai-workflow-builder/README.md.
AI_WORKFLOW_BUILDER_HOURLY_USER=100
AI_WORKFLOW_BUILDER_HOURLY_ORG=500
AI_WORKFLOW_BUILDER_DAILY_ORG=2000
