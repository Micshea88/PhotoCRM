# --- Database (Vercel Postgres / Neon) ---
DATABASE_URL=

# --- Better Auth ---
# 32+ char random string; generate with: openssl rand -hex 32
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000

# --- Resend (email) ---
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@example.com

# --- Vercel Blob (file uploads) ---
BLOB_READ_WRITE_TOKEN=

# --- Background jobs ---
CRON_SECRET=
QUEUE_SECRET=

# --- Sentry ---
SENTRY_DSN=
SENTRY_AUTH_TOKEN=

# --- App URLs ---
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Test/staging override ---
# Set to "false" only for E2E or staging to skip email verification on sign-up.
# Production should never set this to "false".
AUTH_REQUIRE_EMAIL_VERIFICATION=true
