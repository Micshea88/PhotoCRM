# --- Database (Vercel Postgres / Neon) ---
# Runtime + tests. Locally, connect as `pathway_app` (NOSUPERUSER, NOBYPASSRLS)
# so RLS policies actually enforce against the app's identity, the way Neon
# does in production. Example: postgres://pathway_app:pathway_app_dev@localhost:5432/pathway_dev
DATABASE_URL=
# Admin URL — drizzle-kit migrate (DDL) and scripts/seed.ts. Connects as
# the docker superuser locally; Neon's owner role in production. Example:
# postgres://postgres:postgres@localhost:5432/pathway_dev
DATABASE_URL_ADMIN=

# --- Better Auth ---
# 32+ char random string; generate with: openssl rand -hex 32
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000

# --- Google sign-in (OPTIONAL) ---
# Optional alternate to email+password. Leave BLANK to disable (the
# "Continue with Google" button is hidden and email/password is the only path).
# Register an OAuth client in Google Cloud Console; redirect URI:
#   <BETTER_AUTH_URL>/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Pathway-staff account recovery (OPTIONAL) ---
# Comma-separated emails allowed into the cross-tenant recovery console
# (/admin/recovery). Blank = console 404s for everyone. Credential-recovery only.
PATHWAY_SUPERADMIN_EMAILS=

# --- Resend (email) ---
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@example.com
# Optional display name composed into the From: header at send time.
# When set, recipients see "K&K Photo CRM <noreply@example.com>" in
# their inbox client. When unset, the bare email is used. Kept
# separate from RESEND_FROM_EMAIL so the email var stays z.email()-
# validatable (RFC 5322 mailbox-with-display-name format isn't a
# plain email and would fail the schema).
RESEND_FROM_NAME=

# --- Vercel Blob (file uploads) ---
BLOB_READ_WRITE_TOKEN=

# --- Background jobs ---
CRON_SECRET=
QUEUE_SECRET=

# --- Sentry ---
# Server-side DSN. Same value goes in NEXT_PUBLIC_SENTRY_DSN — both are needed
# (Next.js does NOT inline server-only env vars into the browser bundle, so
# client-side errors require the NEXT_PUBLIC_ variant separately).
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
# Required for source-map upload in production builds. Your Sentry org slug
# and project slug — find them in the Sentry project URL.
SENTRY_ORG=
SENTRY_PROJECT=

# --- App URLs ---
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- AI Workflow Builder (optional; graceful disable when key missing) ---
# Anthropic API key. Leave blank to disable the AI Workflow Builder —
# the rest of the engine is unaffected; users see a clear
# "AI Workflow Builder is not configured" error if they try to use it.
ANTHROPIC_API_KEY=
# Default model. Override only if you need a specific Claude version.
AI_WORKFLOW_BUILDER_MODEL=claude-sonnet-4-6
# Rate-limit defaults — OPERATOR-COST / abuse backstop, NOT a user paywall.
# Defaults are generous (invisible to honest use; hard ceiling against
# runaway / abuse / bug). See src/modules/ai-workflow-builder/README.md.
AI_WORKFLOW_BUILDER_HOURLY_USER=100
AI_WORKFLOW_BUILDER_HOURLY_ORG=500
AI_WORKFLOW_BUILDER_DAILY_ORG=2000
# AI Assistant rate limits (module 17). Same operator-cost-backstop
# posture as the builder — NOT a user paywall. Higher defaults because
# conversation volume is higher than drafting volume.
AI_ASSISTANT_HOURLY_USER=300
AI_ASSISTANT_HOURLY_ORG=1500
AI_ASSISTANT_DAILY_ORG=6000

# --- Telephony (RingCentral OAuth) ---
# Encryption-at-rest key for stored OAuth tokens. 32 bytes hex (64 chars).
# Generate with: openssl rand -hex 32
# REQUIRED — losing or changing this value renders every stored ciphertext
# permanently undecryptable; recovery = users re-connect their accounts.
# See src/lib/crypto.ts header for the recovery path.
TELEPHONY_ENCRYPTION_KEY=
# RingCentral OAuth credentials (issued by the RC developer console).
# Sandbox URL: https://platform.devtest.ringcentral.com
# Production URL: https://platform.ringcentral.com
# Optional today (step 1 is table-only); required when the OAuth flow ships.
RINGCENTRAL_CLIENT_ID=
RINGCENTRAL_CLIENT_SECRET=
RINGCENTRAL_SERVER_URL=

# --- Nylas email connector (Commit 4) ---
# Per-photographer Gmail/Outlook/IMAP connection brokered by Nylas hosted auth.
# NYLAS_ENCRYPTION_KEY is REQUIRED (its own security domain, NOT the telephony
# key) — encrypts the stored grant at rest. Generate: openssl rand -hex 32
NYLAS_ENCRYPTION_KEY=
# Nylas application credentials (paste from the Nylas dashboard). Optional so a
# fresh clone still boots; the connect flow errors clearly if missing.
NYLAS_API_KEY=
NYLAS_CLIENT_ID=
# Regional API base, e.g. https://api.us.nylas.com or https://api.eu.nylas.com
NYLAS_API_URI=
# Webhook signing secret (shown once when the subscription is created in the
# Nylas dashboard). Optional; the inbound route rejects deliveries when unset.
NYLAS_WEBHOOK_SECRET=
